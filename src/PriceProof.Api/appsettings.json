{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=priceproof;Username=priceproof;Password=priceproof"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  },
  "Uploads": {
    "StorageRootPath": "storage",
    "MaxFileSizeBytes": 20971520,
    "MaxFileNameLength": 120,
    "MaxCategoryLength": 48,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".webp", ".pdf", ".txt", ".mp3", ".m4a", ".wav", ".mp4", ".webm"],
    "AllowedContentTypes": ["image/jpeg", "image/png", "image/webp", "application/pdf", "text/plain", "audio/mpeg", "audio/mp4", "audio/wav", "video/mp4", "video/webm"]
  },
  "Ocr": {
    "Enabled": false,
    "PrimaryProvider": "AzureDocumentIntelligence",
    "SecondaryProvider": "GoogleVision",
    "RetryCount": 1,
    "RequestTimeoutSeconds": 20,
    "ProviderRetryCount": 2,
    "ProviderRetryDelayMilliseconds": 500,
    "StorageRootPath": "storage",
    "AzureDocumentIntelligence": {
      "Endpoint": "",
      "ApiKey": "",
      "ModelId": "prebuilt-receipt",
      "ApiVersion": "2024-11-30",
      "PollingIntervalMilliseconds": 1000,
      "MaxPollingAttempts": 20
    },
    "GoogleVision": {
      "ApiKey": ""
    }
  },
  "ComplaintPacks": {
    "Enabled": true,
    "StorageRootPath": "storage",
    "Title": "PriceProof SA Complaint Pack",
    "LogoText": "PP",
    "IncludeEvidencePreviews": true,
    "IncludeEvidenceReferences": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  }
}
