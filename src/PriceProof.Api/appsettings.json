{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "BootstrapAdmin": {
    "Email": "",
    "DisplayName": "",
    "Password": ""
  },
  "AccountSecurity": {
    "RequireVerifiedEmailForSignIn": true,
    "EmailVerificationTokenLifetimeHours": 24,
    "PasswordResetTokenLifetimeMinutes": 60,
    "MaxFailedSignInAttempts": 5,
    "LockoutDurationMinutes": 15,
    "PublicAppUrl": ""
  },
  "SharedStorage": {
    "StorageKeyPrefix": "db://",
    "EnableLegacyFileFallback": true,
    "LegacyFileRootPath": "storage"
  },
  "Uploads": {
    "MaxFileSizeBytes": 20971520,
    "MaxFileNameLength": 120,
    "MaxCategoryLength": 48,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".webp", ".pdf", ".txt", ".mp3", ".m4a", ".wav", ".mp4", ".webm"],
    "AllowedContentTypes": ["image/jpeg", "image/png", "image/webp", "application/pdf", "text/plain", "audio/mpeg", "audio/mp4", "audio/wav", "video/mp4", "video/webm"]
  },
  "Ocr": {
    "Enabled": false,
    "PrimaryProvider": "AzureDocumentIntelligence",
    "SecondaryProvider": "GoogleVision",
    "RetryCount": 1,
    "RequestTimeoutSeconds": 20,
    "ProviderRetryCount": 2,
    "ProviderRetryDelayMilliseconds": 500,
    "AzureDocumentIntelligence": {
      "Endpoint": "",
      "ApiKey": "",
      "ModelId": "prebuilt-receipt",
      "ApiVersion": "2024-11-30",
      "PollingIntervalMilliseconds": 1000,
      "MaxPollingAttempts": 20
    },
    "GoogleVision": {
      "ApiKey": ""
    }
  },
  "ComplaintPacks": {
    "Enabled": true,
    "Title": "PriceProof SA Complaint Pack",
    "LogoText": "PP",
    "IncludeEvidencePreviews": true,
    "IncludeEvidenceReferences": true
  },
  "EmailDelivery": {
    "Provider": "LogOnly",
    "FromAddress": "",
    "FromDisplayName": "PriceProof SA",
    "Smtp": {
      "Host": "",
      "Port": 587,
      "UserName": "",
      "Password": "",
      "EnableSsl": true
    }
  },
  "SessionAuth": {
    "CookieName": "priceproof.session",
    "SessionLifetimeHours": 12
  },
  "OpenTelemetry": {
    "Enabled": false,
    "ServiceName": "PriceProof.Api",
    "ServiceVersion": "",
    "OtlpEndpoint": "",
    "EnableConsoleExporter": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  }
}
